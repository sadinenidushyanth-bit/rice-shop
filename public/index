          style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:12px;color:var(--text3);font-family:var(--font);padding:4px 6px;font-weight:600">
          Show
        </button>
      </div>
    </div>
    <button class="btn btn-primary btn-full" id="login-btn" onclick="doLogin()" disabled style="margin-top:4px">Connecting...</button>
    <p style="font-size:11px;color:var(--text3);text-align:center;margin-top:14px;line-height:1.6;">
      Use your <strong>email address</strong> and password to sign in.<br>
      New user? Ask your admin to add you in <strong>Permissions</strong>.
