        onkeydown="if(event.key==='Enter')document.getElementById('auth-pass').focus()">
    </div>
    <div class="form-group">
      <label class="form-label">Password</label>
      <div style="position:relative">
        <input type="password" id="auth-pass" class="form-control" placeholder="••••••••"
          autocomplete="current-password" style="padding-right:56px"
          onkeydown="if(event.key==='Enter'||event.keyCode===13)doLogin()">
