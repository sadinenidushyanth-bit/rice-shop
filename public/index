<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=yes">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<title>Rice Shop Manager</title>
<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
  import { getFirestore, collection, addDoc, getDocs, updateDoc, deleteDoc, doc, onSnapshot, query, orderBy, setDoc, getDoc, serverTimestamp, increment, where } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";
  import { getAuth, signInWithEmailAndPassword, signOut, onAuthStateChanged, createUserWithEmailAndPassword } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";
  import { getStorage, ref, uploadBytes, uploadString, getDownloadURL, deleteObject } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-storage.js";
  import { getFunctions, httpsCallable } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-functions.js";

  const firebaseConfig = {
    apiKey: "AIzaSyCHR0efe8c5NrMQdPNS90Otrj6fPXTi4B0",
    authDomain: "rice-shop-59c6a.firebaseapp.com",
    projectId: "rice-shop-59c6a",
    storageBucket: "rice-shop-59c6a.firebasestorage.app",
    messagingSenderId: "632800299142",
    appId: "1:632800299142:web:204f249cf28b48b1346907"
  };

  let app, db, auth, storage, functions;
  try {
    app      = initializeApp(firebaseConfig);
    db       = getFirestore(app);
    auth     = getAuth(app);
    storage  = getStorage(app);
    functions = getFunctions(app, "asia-south1");
  } catch (e) {
    console.error("Firebase initialization failed", e);
  }

  window._db        = db;
  window._auth      = auth;
  window._storage   = storage;
  window._functions = functions;
  window._fb = {
    collection, addDoc, getDocs, updateDoc, deleteDoc, doc,
    onSnapshot, query, orderBy, setDoc, getDoc, serverTimestamp, increment, where,
    ref, uploadBytes, uploadString, getDownloadURL, deleteObject,
    signInWithEmailAndPassword, signOut, onAuthStateChanged, createUserWithEmailAndPassword,
    httpsCallable
  };
  window._fbReady = true;
  document.dispatchEvent(new Event('firebase-ready'));
</script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');
:root {
  --bg:#F7F5F0;--surface:#fff;--surface2:#F0EDE6;--border:#E2DDD5;
  --text:#1A1714;--text2:#6B6560;--text3:#A09A93;
  --green:#2D7A5F;--green-light:#E6F4EE;--green-dark:#1d5c47;
  --amber:#B45309;--amber-light:#FEF3C7;
  --red:#B91C1C;--red-light:#FEE2E2;
  --blue:#1d4ed8;--blue-light:#EFF6FF;
  --purple:#7c3aed;--purple-light:#EDE9FE;
  --wa:#25D366;--wa-dark:#128C7E;
  --radius:12px;--radius-sm:8px;
  --shadow:0 1px 3px rgba(0,0,0,0.07),0 1px 2px rgba(0,0,0,0.05);
  --font:'Plus Jakarta Sans',system-ui,sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{overflow-x:hidden;width:100%;max-width:100%;}
body{font-family:var(--font);background:var(--bg);color:var(--text);min-height:100vh;font-size:15px;}
.hidden{display:none!important;}
/* Prevent any flex child (inputs, buttons, selects) from forcing the row wider than the screen */
.section-head > *, .filter-row > *, .nav > *{min-width:0;}
input.form-control, select.form-control{min-width:0;}

/* ── AUTH SCREEN ── */
.auth-screen{position:fixed;inset:0;background:var(--bg);z-index:400;display:flex;align-items:center;justify-content:center;padding:24px;}
.auth-box{background:var(--surface);border-radius:var(--radius);padding:28px 24px;width:100%;max-width:380px;border:1px solid var(--border);box-shadow:var(--shadow);}
.auth-logo{font-size:44px;text-align:center;margin-bottom:10px;}
.auth-title{font-size:20px;font-weight:700;text-align:center;margin-bottom:4px;}
.auth-sub{font-size:13px;color:var(--text3);text-align:center;margin-bottom:22px;line-height:1.5;}
.auth-error{background:var(--red-light);color:var(--red);border-radius:var(--radius-sm);padding:10px 12px;font-size:13px;margin-bottom:12px;display:none;}

/* ── HEADER ── */
.header{background:var(--surface);border-bottom:1px solid var(--border);padding:14px 16px 0;position:sticky;top:0;z-index:50;}
.header-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.shop-name{font-size:18px;font-weight:700;letter-spacing:-0.3px;}
.shop-name span{color:var(--green);}
.header-right{display:flex;align-items:center;gap:8px;}
.user-badge{font-size:11px;padding:3px 10px;border-radius:20px;background:var(--green-light);color:var(--green);font-weight:600;display:flex;align-items:center;gap:4px;}
.user-badge.worker{background:var(--blue-light);color:var(--blue);}
.logout-btn{font-size:12px;color:var(--text3);background:none;border:1px solid var(--border);border-radius:20px;padding:3px 10px;cursor:pointer;font-family:var(--font);}

/* ── NAV ── */
.nav{display:flex;gap:0;overflow-x:auto;scrollbar-width:none;}
.nav::-webkit-scrollbar{display:none;}
.nav-btn{flex-shrink:0;border:none;background:none;padding:10px 12px;font-size:13px;font-weight:500;color:var(--text3);cursor:pointer;border-bottom:2px solid transparent;font-family:var(--font);display:flex;align-items:center;gap:5px;transition:color .15s;}
.nav-btn.active{color:var(--green);border-bottom-color:var(--green);}
.nav-btn svg{width:15px;height:15px;}
.nav-btn.locked{opacity:0.35;cursor:not-allowed;}

/* ── MAIN ── */
.main{padding:16px;max-width:600px;margin:0 auto;}

/* ── MOBILE SAFE AREA ── */
@supports(padding:max(0px)){
  .header{padding-left:max(16px,env(safe-area-inset-left));padding-right:max(16px,env(safe-area-inset-right));}
  .main{padding-left:max(16px,env(safe-area-inset-left));padding-right:max(16px,env(safe-area-inset-right));}
}

/* ── METRICS ── */
.metrics{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:16px;}
.metric-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:14px;box-shadow:var(--shadow);}
.metric-label{font-size:11px;font-weight:500;color:var(--text3);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;}
.metric-value{font-size:24px;font-weight:700;letter-spacing:-0.5px;}
.metric-sub{font-size:12px;color:var(--text3);margin-top:2px;}
.metric-accent{color:var(--green);}

/* ── ALERT ── */
.alert{border-radius:var(--radius-sm);padding:10px 14px;font-size:13px;margin-bottom:12px;display:flex;gap:8px;align-items:flex-start;}
.alert.amber{background:var(--amber-light);color:var(--amber);border:1px solid #fde68a;}
.alert.red{background:var(--red-light);color:var(--red);border:1px solid #fecaca;}
.alert.green{background:var(--green-light);color:var(--green);border:1px solid #a7f3d0;}

/* ── BUTTONS ── */
.btn{border:1px solid var(--border);border-radius:var(--radius-sm);padding:8px 14px;font-size:13px;font-weight:500;cursor:pointer;background:var(--surface);color:var(--text);font-family:var(--font);display:inline-flex;align-items:center;gap:5px;transition:background .12s;}
.btn:hover{background:var(--surface2);}
.btn-primary{background:var(--green);color:#fff;border-color:var(--green);}
.btn-primary:hover{background:var(--green-dark);border-color:var(--green-dark);}
.btn-danger{color:var(--red);border-color:var(--border);}
.btn-danger:hover{background:var(--red-light);}
.btn-wa{background:var(--wa);color:#fff;border-color:var(--wa);}
.btn-wa:hover{background:var(--wa-dark);border-color:var(--wa-dark);}
.btn-blue{background:var(--blue);color:#fff;border-color:var(--blue);}
.btn-full{width:100%;justify-content:center;padding:11px;font-size:14px;}
.btn svg{width:15px;height:15px;flex-shrink:0;}
.btn:disabled{opacity:0.4;cursor:not-allowed;}

/* ── SECTION HEAD ── */
.section-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px;}
.section-title{font-size:15px;font-weight:600;}

/* ── FILTER ROW ── */
.filter-row{display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap;}
.filter-btn{font-size:12px;padding:5px 12px;border-radius:20px;border:1px solid var(--border);background:var(--surface);cursor:pointer;font-family:var(--font);font-weight:500;color:var(--text2);transition:background .12s;}
.filter-btn.active{background:var(--green);color:#fff;border-color:var(--green);}

/* ── BAG GRID ── */
.bag-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:12px;}
.bag-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow);}
.bag-photo{width:100%;height:100px;object-fit:cover;background:var(--surface2);display:flex;align-items:center;justify-content:center;font-size:38px;}
.bag-photo img{width:100%;height:100%;object-fit:cover;}
.bag-body{padding:10px;}
.bag-name{font-size:14px;font-weight:600;margin-bottom:1px;}
.bag-wt{font-size:12px;color:var(--text3);margin-bottom:5px;}
.bag-price{font-size:17px;font-weight:700;color:var(--green);margin-bottom:5px;}
.stock-pill{display:inline-block;font-size:11px;font-weight:500;padding:2px 8px;border-radius:20px;margin-bottom:8px;}
.pill-ok{background:var(--green-light);color:var(--green);}
.pill-low{background:var(--amber-light);color:var(--amber);}
.pill-out{background:var(--red-light);color:var(--red);}
.bag-btns{display:flex;gap:6px;}
.bag-btns .btn{flex:1;justify-content:center;padding:6px 8px;font-size:12px;}

/* ── CARD ── */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px;margin-bottom:14px;box-shadow:var(--shadow);}
.card-title{font-size:15px;font-weight:600;margin-bottom:14px;display:flex;align-items:center;gap:6px;}

/* ── SALE ROW ── */
.sale-row{display:flex;align-items:flex-start;gap:10px;padding:10px 0;border-bottom:1px solid var(--border);}
.sale-row:last-child{border:none;padding-bottom:0;}
.sale-icon{width:36px;height:36px;border-radius:8px;background:var(--green-light);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;}
.sale-info{flex:1;min-width:0;}
.sale-name{font-size:14px;font-weight:600;}
.sale-meta{font-size:12px;color:var(--text3);margin-top:1px;}
.sale-amt{font-size:15px;font-weight:700;color:var(--green);flex-shrink:0;}

/* ── ORDER ROW ── */
.order-row{padding:12px 0;border-bottom:1px solid var(--border);}
.order-row:last-child{border:none;padding-bottom:0;}
.order-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;}
.order-name{font-size:14px;font-weight:600;}
.order-amt{font-size:14px;font-weight:700;color:var(--green);}
.order-meta{font-size:12px;color:var(--text3);margin-bottom:6px;}
.order-items-text{font-size:12px;color:var(--text2);background:var(--surface2);border-radius:6px;padding:6px 8px;margin-bottom:8px;}
.order-footer{display:flex;gap:6px;flex-wrap:wrap;align-items:center;}
.status-badge{font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;}
.s-Pending{background:var(--amber-light);color:var(--amber);}
.s-Confirmed{background:var(--blue-light);color:var(--blue);}
.s-Delivering{background:var(--purple-light);color:var(--purple);}
.s-Delivered{background:var(--green-light);color:var(--green);}
.s-Cancelled{background:var(--red-light);color:var(--red);}

/* ── FORM ── */
.form-group{margin-bottom:13px;}
.form-label{font-size:12px;font-weight:600;color:var(--text2);margin-bottom:5px;display:block;text-transform:uppercase;letter-spacing:0.3px;}
.form-control{width:100%;border:1px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;font-size:14px;font-family:var(--font);background:var(--surface);color:var(--text);transition:border-color .15s;}
.form-control:focus{outline:none;border-color:var(--green);}
textarea.form-control{resize:vertical;min-height:70px;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;}

/* ── IMG UPLOAD ── */
.img-upload{border:2px dashed var(--border);border-radius:var(--radius-sm);height:90px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;position:relative;overflow:hidden;font-size:12px;color:var(--text3);gap:4px;transition:border-color .15s;}
.img-upload:hover{border-color:var(--green);}
.img-upload input{position:absolute;inset:0;opacity:0;cursor:pointer;}
.img-upload img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;}
.img-upload svg{width:22px;height:22px;}

/* ── MODAL ── */
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.5);display:flex;align-items:flex-end;justify-content:center;z-index:200;padding:0;-webkit-overflow-scrolling:touch;}
@media(min-width:540px){.modal-bg{align-items:center;padding:20px;}}
.modal{background:var(--surface);width:100%;max-width:480px;border-radius:20px 20px 0 0;padding:20px 16px env(safe-area-inset-bottom,24px);max-height:85vh;max-height:85dvh;overflow-y:auto;-webkit-overflow-scrolling:touch;overscroll-behavior:contain;}
@media(min-width:540px){.modal{border-radius:16px;padding:22px;max-height:85vh;}}
/* invoice modal — slightly wider and always scrollable */
#invoice-modal .modal{max-width:500px;}
.modal-handle{width:36px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 16px;}
@media(min-width:500px){.modal-handle{display:none;}}
.modal-title{font-size:17px;font-weight:700;margin-bottom:16px;}
.modal-actions{display:flex;gap:8px;margin-top:16px;}
.modal-actions .btn{flex:1;justify-content:center;}

/* ── WA ── */
.wa-bubble{background:#E7F8EE;border-radius:0 14px 14px 14px;padding:12px 14px;font-size:13px;line-height:1.75;white-space:pre-wrap;color:#111;border:1px solid #C5E3CC;margin-bottom:14px;}
.wa-wrap{background:#ECE5DD;border-radius:var(--radius);padding:12px;margin-bottom:14px;}
.wa-time{font-size:11px;color:var(--text3);text-align:right;margin-top:4px;}
.wa-actions{display:flex;gap:8px;flex-wrap:wrap;}

/* ── CUSTOMERS PANEL ── */
.customer-row{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--border);cursor:pointer;}
.customer-row:last-child{border:none;}
.customer-row:hover{background:var(--surface2);margin:0 -16px;padding:10px 16px;border-radius:8px;}
.cust-avatar{width:38px;height:38px;border-radius:50%;background:var(--green-light);display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;color:var(--green);flex-shrink:0;}
.cust-info{flex:1;min-width:0;}
.cust-name{font-size:14px;font-weight:600;}
.cust-meta{font-size:12px;color:var(--text3);}
.cust-wa{background:var(--wa);color:#fff;border:none;border-radius:20px;padding:5px 12px;font-size:12px;cursor:pointer;font-family:var(--font);display:flex;align-items:center;gap:4px;}

/* ── PERMISSIONS ── */
.perm-user-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:14px;margin-bottom:12px;box-shadow:var(--shadow);}
.perm-user-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.perm-user-name{font-size:14px;font-weight:600;}
.perm-user-role{font-size:11px;padding:2px 10px;border-radius:20px;font-weight:600;}
.role-admin{background:var(--green-light);color:var(--green);}
.role-worker{background:var(--blue-light);color:var(--blue);}
.perm-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:6px;}
.perm-toggle{display:flex;align-items:center;justify-content:space-between;background:var(--surface2);border-radius:var(--radius-sm);padding:7px 10px;font-size:12px;font-weight:500;}
.toggle-sw{position:relative;width:34px;height:18px;flex-shrink:0;}
.toggle-sw input{opacity:0;width:0;height:0;}
.toggle-slider{position:absolute;inset:0;background:#ccc;border-radius:18px;cursor:pointer;transition:.2s;}
.toggle-slider:before{content:'';position:absolute;width:14px;height:14px;left:2px;bottom:2px;background:#fff;border-radius:50%;transition:.2s;}
.toggle-sw input:checked+.toggle-slider{background:var(--green);}
.toggle-sw input:checked+.toggle-slider:before{transform:translateX(16px);}

/* ── TOAST ── */
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#1A1714;color:#fff;padding:10px 18px;border-radius:20px;font-size:13px;font-weight:500;z-index:600;opacity:0;transition:opacity .2s;pointer-events:none;white-space:nowrap;}
.toast.show{opacity:1;}

/* ── EMPTY ── */
.empty{text-align:center;padding:2.5rem 1rem;color:var(--text3);font-size:14px;grid-column:1/-1;}
.empty-icon{font-size:40px;margin-bottom:8px;}

/* ── WA MORNING CARD ── */
.morning-card{background:linear-gradient(135deg,#064e3b 0%,#065f46 100%);border-radius:var(--radius);padding:18px;margin-bottom:14px;color:#fff;}
.morning-title{font-size:16px;font-weight:700;margin-bottom:4px;}
.morning-sub{font-size:12px;opacity:0.75;margin-bottom:14px;}
.morning-offer{background:rgba(255,255,255,0.15);border-radius:8px;padding:10px 12px;font-size:13px;margin-bottom:14px;line-height:1.6;}
.morning-actions{display:flex;gap:8px;flex-wrap:wrap;}
.morning-actions .btn{background:rgba(255,255,255,0.15);border-color:rgba(255,255,255,0.3);color:#fff;font-size:13px;}
.morning-actions .btn:hover{background:rgba(255,255,255,0.25);}
.morning-actions .btn-wa{background:var(--wa);border-color:var(--wa);color:#fff;}

/* ── CUSTOMER SELECT ── */
.cust-select-list{max-height:220px;overflow-y:auto;border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:10px;}
.cust-select-row{display:flex;align-items:center;gap:10px;padding:9px 12px;border-bottom:1px solid var(--border);cursor:pointer;}
.cust-select-row:last-child{border:none;}
.cust-select-row:hover{background:var(--surface2);}
.cust-select-row input[type=checkbox]{width:16px;height:16px;accent-color:var(--green);cursor:pointer;}
.cust-select-row.selected{background:var(--green-light);}
.selected-count{font-size:12px;color:var(--green);font-weight:600;margin-bottom:8px;}

/* ── OPEN BAG / LOOSE SALE ── */
.bag-open-banner{background:linear-gradient(135deg,#7c3aed,#6d28d9);color:#fff;border-radius:8px;padding:6px 10px;font-size:11px;font-weight:600;margin-bottom:6px;display:flex;align-items:center;justify-content:space-between;gap:6px;}
.bag-open-banner .kg-left{font-size:14px;font-weight:700;}
.loose-progress{height:5px;border-radius:3px;background:rgba(255,255,255,0.25);margin-top:4px;overflow:hidden;}
.loose-progress-bar{height:100%;background:#fff;border-radius:3px;transition:width .3s;}
.btn-open-bag{background:var(--purple-light);color:var(--purple);border-color:var(--purple-light);font-size:11px;padding:5px 8px;}
.btn-open-bag:hover{background:#ddd6fe;}
.btn-sell-loose{background:var(--purple);color:#fff;border-color:var(--purple);font-size:11px;padding:5px 8px;}
.btn-sell-loose:hover{background:#6d28d9;}
/* loose sale modal */
.loose-bag-info{display:flex;align-items:center;gap:12px;background:var(--purple-light);border-radius:var(--radius-sm);padding:12px;margin-bottom:14px;}
.loose-bag-img{width:52px;height:52px;border-radius:8px;background:var(--surface);display:flex;align-items:center;justify-content:center;font-size:26px;flex-shrink:0;overflow:hidden;}
.loose-bag-img img{width:100%;height:100%;object-fit:cover;}
.loose-avail{font-size:12px;color:var(--purple);font-weight:600;margin-top:2px;}

@media(max-width:400px){.form-row{grid-template-columns:1fr;}}
@media(max-width:480px){
  .section-head{flex-direction:column;align-items:stretch;}
  .section-head input[type="text"]{max-width:100%!important;width:100%!important;order:2;}
  .section-head .section-title{order:1;}
  .section-head button{order:3;}
}

/* ── INVOICE (modal preview) ── */
.inv-header{background:linear-gradient(135deg,#064e3b,#065f46);color:#fff;padding:14px 16px;}
.inv-shop{font-size:15px;font-weight:700;margin-bottom:2px;}
.inv-sub{font-size:11px;opacity:0.8;}
.inv-body{padding:12px 14px;}
.inv-section{margin-bottom:10px;padding-bottom:10px;border-bottom:1px solid var(--border);}
.inv-section:last-child{border:none;margin-bottom:0;padding-bottom:0;}
.inv-label{font-size:10px;text-transform:uppercase;letter-spacing:0.5px;color:var(--text3);font-weight:700;margin-bottom:6px;}
.inv-row{display:flex;justify-content:space-between;align-items:flex-start;font-size:13px;padding:4px 0;gap:8px;}
.inv-row span:last-child{text-align:right;font-weight:500;flex-shrink:0;max-width:60%;}
.inv-row.bold{font-weight:700;}
.inv-row.total{background:var(--green-light);padding:8px 10px;border-radius:6px;margin-top:4px;color:var(--green);font-weight:700;font-size:14px;}
/* print handled via popup window */

/* ── PRINT ── */
#print-area{display:none;}
@media print{
  body > *{display:none!important;}
  #print-area{display:block!important;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif;font-size:14px;color:#111;background:#fff;padding:0;margin:0;}
  #print-area .p-wrap{max-width:100%;border:none;}
  #print-area .p-head{background:#064e3b!important;-webkit-print-color-adjust:exact;print-color-adjust:exact;color:#fff;padding:16px;}
  #print-area .p-head h1{font-size:17px;font-weight:700;margin-bottom:3px;}
  #print-area .p-head p{font-size:11px;opacity:0.85;}
  #print-area .p-body{padding:14px;}
  #print-area .p-section{margin-bottom:12px;padding-bottom:12px;border-bottom:1px solid #eee;}
  #print-area .p-section:last-child{border:none;}
  #print-area .p-label{font-size:10px;text-transform:uppercase;letter-spacing:0.5px;color:#888;font-weight:700;margin-bottom:6px;}
  #print-area table{width:100%;border-collapse:collapse;}
  #print-area td{padding:5px 0;font-size:13px;vertical-align:top;}
  #print-area td:last-child{text-align:right;font-weight:500;}
  #print-area .p-total td{background:#e6f4ee!important;-webkit-print-color-adjust:exact;print-color-adjust:exact;color:#1d5c47;font-weight:700;font-size:15px;padding:8px 6px;}
  #print-area .p-thanks{text-align:center;font-size:12px;color:#888;margin-top:12px;line-height:1.7;border-top:1px dashed #ddd;padding-top:10px;}
  @page{margin:8mm;size:A5;}
}


.profit-row{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border);}
.profit-row:last-child{border:none;}
.profit-label{font-size:14px;font-weight:600;}
.profit-meta{font-size:12px;color:var(--text3);}
.profit-right{text-align:right;}
.profit-amt{font-size:15px;font-weight:700;color:var(--green);}
.profit-margin{font-size:11px;font-weight:600;padding:2px 7px;border-radius:20px;margin-top:2px;display:inline-block;}
.pm-good{background:var(--green-light);color:var(--green);}
.pm-ok{background:var(--amber-light);color:var(--amber);}
.pm-low{background:var(--red-light);color:var(--red);}
.sale-profit{font-size:12px;color:var(--green);font-weight:600;}
.sale-profit.loss{color:var(--red);}
</style>
