async function loadUserData(uid) {
  const { doc, getDoc } = window._fb;
  const snap = await getDoc(doc(window._db,'users',uid));
  if (snap.exists()) {
    currentUserData = snap.data();
  } else {
    // First user ever or specific admin — make admin
    const { setDoc } = window._fb;
    const name = currentUser.email === 'sadinenidushaynth@gmail.com' ? 'Dushyath' : currentUser.email;
    currentUserData = { name: name, email: currentUser.email, role:'admin', permissions: getAdminPerms() };
    await setDoc(doc(window._db,'users',uid), currentUserData);
  }
  const badge = document.getElementById('user-badge');
  badge.textContent = (currentUserData.name||currentUserData.email||'User') + (currentUserData.role==='admin'?' 👑':'');
  badge.className = 'user-badge' + (currentUserData.role==='admin'?'':' worker');
