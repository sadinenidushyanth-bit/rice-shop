          🌾 Thank you for your order, ${s.customer||'valued customer'}!<br>
          Fresh rice delivered to your door 🙏
        </div>
      </div>
    </div>`;

  // Small delay so DOM renders before print dialog opens
  setTimeout(()=>{
    window.print();
    // Clear print area after printing
    setTimeout(()=>{ printArea.innerHTML=''; }, 2000);
  }, 150);
}

// ══════════════════════════════════════════════
// PROFIT TAB
// ══════════════════════════════════════════════
let profitFilter = 'month';
function setProfitFilter(f, btn) {
  profitFilter = f;
  document.querySelectorAll('#tab-profit .filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  if (f !== 'custom') {
    document.getElementById('profit-start-date').value = '';
    document.getElementById('profit-end-date').value = '';
  }
  renderProfit();
}

function customProfitFilter() {
  const start = document.getElementById('profit-start-date').value;
  const end = document.getElementById('profit-end-date').value;
  if (!start && !end) return;
  profitFilter = 'custom';
  document.querySelectorAll('#tab-profit .filter-btn').forEach(b => b.classList.remove('active'));
  renderProfit();
}

function renderProfit(){
  const now = new Date();
  const filtered = sales.filter(s=>{
    const d = new Date(s.date);
    if(profitFilter==='today') return d.toDateString()===now.toDateString();
    if(profitFilter==='week'){const w=new Date(now);w.setDate(now.getDate()-7);return d>=w;}
    if(profitFilter==='month') return d.getMonth()===now.getMonth()&&d.getFullYear()===now.getFullYear();
    if(profitFilter==='custom') {
      const start = document.getElementById('profit-start-date').value;
      const end = document.getElementById('profit-end-date').value;
      const startTime = start ? new Date(start).setHours(0,0,0,0) : 0;
      const endTime = end ? new Date(end).setHours(23,59,59,999) : Infinity;
      return d.getTime() >= startTime && d.getTime() <= endTime;
    }
    return true;
  });

  const totalRev = filtered.reduce((s,x)=>s+x.total,0);
  const totalCost = filtered.reduce((s,x)=>s+(x.costPerBag||0)*x.qty,0);
  const totalProfit = totalRev - totalCost;
  const totalBagsSold = filtered.reduce((s,x)=>s+x.qty,0);
  const avgMargin = totalCost>0 ? Math.round((totalProfit/totalCost)*100) : 0;

  document.getElementById('profit-metrics').innerHTML=`
    <div class="metric-card"><div class="metric-label">Revenue</div><div class="metric-value metric-accent">₹${totalRev.toLocaleString('en-IN')}</div><div class="metric-sub">${totalBagsSold} bags sold</div></div>
    <div class="metric-card"><div class="metric-label">Vendor cost</div><div class="metric-value" style="color:var(--red)">₹${totalCost.toLocaleString('en-IN')}</div><div class="metric-sub">what you paid</div></div>
    <div class="metric-card"><div class="metric-label">Net profit</div><div class="metric-value" style="color:${totalProfit>=0?'var(--green)':'var(--red)'}">₹${totalProfit.toLocaleString('en-IN')}</div></div>
    <div class="metric-card"><div class="metric-label">Avg margin</div><div class="metric-value" style="color:${avgMargin>=15?'var(--green)':avgMargin>=5?'var(--amber)':'var(--red)'}">${avgMargin}%</div><div class="metric-sub">above vendor cost</div></div>`;

  // Per product breakdown
  const byProduct = {};
  filtered.forEach(s=>{
    if(!byProduct[s.bagName]) byProduct[s.bagName]={name:s.bagName,weight:s.weight||'',qty:0,revenue:0,cost:0,profit:0};
    byProduct[s.bagName].qty += s.qty;
    byProduct[s.bagName].revenue += s.total;
    byProduct[s.bagName].cost += (s.costPerBag||0)*s.qty;
    byProduct[s.bagName].profit += s.profit||0;
  });
  const products = Object.values(byProduct).sort((a,b)=>b.profit-a.profit);
  const ppEl = document.getElementById('profit-per-product');
  if(!products.length){ppEl.innerHTML=`<div class="empty" style="padding:1.5rem 0"><div class="empty-icon">📊</div>No sales in this period.</div>`;document.getElementById('profit-sales-list').innerHTML='';return;}
  ppEl.innerHTML = products.map(p=>{
    const margin = p.cost>0 ? Math.round(p.profit/p.cost*100) : 0;
    const mc = margin>=15?'pm-good':margin>=5?'pm-ok':'pm-low';
    return `<div class="profit-row">
      <div><div class="profit-label">${p.name}</div><div class="profit-meta">${p.weight} · ${p.qty} bags sold</div></div>
      <div class="profit-right">
        <div class="profit-amt">₹${p.profit.toLocaleString('en-IN')}</div>
        <div><span class="profit-margin ${mc}">${margin}% margin</span></div>
        <div style="font-size:11px;color:var(--text3)">Rev ₹${p.revenue.toLocaleString('en-IN')} · Cost ₹${p.cost.toLocaleString('en-IN')}</div>
      </div>
    </div>`;
  }).join('');

  // Sales list with profit per sale
  const salesEl = document.getElementById('profit-sales-list');
  const recentFiltered = filtered.slice(0,30);
  if(!recentFiltered.length){salesEl.innerHTML='';return;}
  salesEl.innerHTML = recentFiltered.map(s=>{
    const profit = s.profit ?? (s.total - (s.costPerBag||0)*s.qty);
    const margin = (s.costPerBag&&s.costPerBag>0) ? Math.round((s.pricePerBag-s.costPerBag)/s.costPerBag*100) : null;
    const d = new Date(s.date);
    const ds = d.toLocaleDateString('en-IN',{day:'numeric',month:'short'})+' '+d.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'});
    const typeIcon = s.type==='delivery'?'🛵':s.type==='whatsapp'?'💬':'🏪';
    return `<div class="sale-row">
      <div class="sale-icon">${typeIcon}</div>
      <div class="sale-info">
        <div class="sale-name">${s.bagName} × ${s.qty} ${s.invoiceNo?`<span style="font-size:10px;color:var(--text3)">${s.invoiceNo}</span>`:''}
          ${(s.type==='whatsapp'||s.type==='delivery')?`<button onclick="reshowInvoice('${s.id}')" style="background:var(--blue-light);color:var(--blue);border:none;border-radius:6px;padding:2px 7px;font-size:10px;cursor:pointer;margin-left:4px">🧾 Invoice</button>`:''}</div>
        <div class="sale-meta">${s.customer||'Walk-in'} · Cost ₹${((s.costPerBag||0)*s.qty).toLocaleString('en-IN')} · Sold ₹${s.total.toLocaleString('en-IN')} · ${ds}</div>
      </div>
      <div style="text-align:right">
        <div class="sale-profit ${profit<0?'loss':''}">+₹${profit.toLocaleString('en-IN')}</div>
        ${margin!==null?`<div style="font-size:11px;color:var(--text3)">${margin}% margin</div>`:''}
      </div>
    </div>`;
  }).join('');
}

function reshowInvoice(saleId){
  const s = sales.find(x=>x.id===saleId);
  if(s) showInvoice(s);
}
function openOrderInvoice(orderId){
  const o = orders.find(x=>x.id===orderId);
  if(!o) return;
  // Build a sale-like object from the order
  const fakeSale = {
    orderId: o.orderId,
    invoiceNo: o.invoiceNo || ('INV-'+o.id.slice(-6).toUpperCase()),
    customer: o.name,
    phone: o.phone,
    address: o.address+(o.landmark?' · '+o.landmark:''),
    bagName: o.items || 'See items below',
    weight: '',
    qty: 1,
    pricePerBag: o.total,
    costPerBag: 0,
    total: o.total,
    date: o.date,
    type: 'whatsapp',
    // Override subtotal display for orders
    _isOrder: true,
    _itemsText: o.items,
    _payment: o.payment
  };
  showInvoice(fakeSale);
}

// ══════════════════════════════════════════════
// OPEN BAG — LOOSE SALES
// ══════════════════════════════════════════════

// Parse bag weight string like "25 kg" → 25, "500 g" → 0.5
function parseBagWeightKg(w){
  if(!w) return 0;
  const n=parseFloat(w);
  if(isNaN(n)) return 0;
  if(w.toLowerCase().includes('g')&&!w.toLowerCase().includes('kg')) return n/1000;
  return n; // default kg
}

let openingBagId = null;

function openOpenBagModal(bagId){
  const b = bags.find(x=>x.id===bagId);
  if(!b) return;
  if(Number(b.stock)<=0){ toast('No full bags to open'); return; }
  openingBagId = bagId;
  document.getElementById('ob-title').textContent = `Open a bag — ${b.name}`;
  document.getElementById('ob-name').textContent = b.name;
  document.getElementById('ob-weight').textContent = b.weight+' bag';
  document.getElementById('ob-stock').textContent = `${b.stock} bags in stock · opening 1`;
  const imgEl = document.getElementById('ob-img');
  imgEl.innerHTML = b.img ? `<img src="${b.img}" style="width:100%;height:100%;object-fit:cover;border-radius:8px">` : '🌾';
  // Suggest per-kg price from bag price
  const kgWeight = parseBagWeightKg(b.weight);
  const suggestedPerKg = kgWeight>0 ? Math.ceil(Number(b.price||0)/kgWeight) : '';
  document.getElementById('ob-price-per-kg').value = b.pricePerKg || suggestedPerKg || '';
  document.getElementById('ob-preview').style.display='none';
  document.getElementById('open-bag-modal').classList.remove('hidden');
  updateOpenBagPreview();
}

function updateOpenBagPreview(){
  const b = bags.find(x=>x.id===openingBagId);
  if(!b) return;
  const kgWeight = parseBagWeightKg(b.weight);
  const pricePerKg = Number(document.getElementById('ob-price-per-kg').value)||0;
  const prev = document.getElementById('ob-preview');
  if(!pricePerKg){ prev.style.display='none'; return; }
  const vendorCostPerKg = kgWeight>0 ? Number(b.cost||0)/kgWeight : 0;
  const profitPerKg = pricePerKg - vendorCostPerKg;
  prev.style.display='block';
  prev.innerHTML = `📦 Opens <strong>${kgWeight} kg</strong> for loose selling<br>
    💵 Selling at <strong>₹${pricePerKg}/kg</strong><br>
    ${vendorCostPerKg>0?`🏭 Vendor cost ₹${vendorCostPerKg.toFixed(1)}/kg · Profit <strong>₹${profitPerKg.toFixed(1)}/kg</strong><br>`:''}
    💰 If all sold: <strong>₹${(pricePerKg*kgWeight).toLocaleString('en-IN')}</strong> revenue`;
}

async function confirmOpenBag(){
  const b = bags.find(x=>x.id===openingBagId);
  if(!b) return;
  const pricePerKg = Number(document.getElementById('ob-price-per-kg').value);
  if(!pricePerKg){ toast('Please enter price per kg'); return; }
  if(Number(b.stock)<=0){ toast('No bags in stock'); return; }
  const kgWeight = parseBagWeightKg(b.weight);
  const orderId  = 'OB-'+Date.now().toString().slice(-7); // e.g. OB-4521367
  const btn = document.getElementById('ob-confirm-btn');
  btn.textContent='Opening...'; btn.disabled=true;
  const {doc, updateDoc, addDoc, collection} = window._fb;
  // 1. Create a record in openedBags collection
  await addDoc(collection(window._db,'openedBags'),{
    orderId,
    bagId:      openingBagId,
    bagName:    b.name,
    bagWeight:  b.weight,
    originalKg: kgWeight,
    remainingKg:kgWeight,
    pricePerKg,
    costPerKg:  kgWeight>0 ? Number(b.cost||0)/kgWeight : 0,
    openedAt:   Date.now(),
    openedBy:   currentUser?.email||''
  });
  // 2. Reduce bag stock by 1
  await updateDoc(doc(window._db,'bags',openingBagId),{
    stock: Number(b.stock)-1
  });
  closeModal('open-bag-modal');
  btn.textContent='📦 Open this bag'; btn.disabled=false;
  toast(`${orderId} — ${b.name} opened! ${kgWeight} kg @ ₹${pricePerKg}/kg`);
}

async function deleteOpenBag(openBagDocId, bagId, remainingKg){
  const ob = openedBags.find(x=>x.id===openBagDocId);
  if(!ob) return;
  const remKg = Number(remainingKg||ob.remainingKg||0);
  const origKg = Number(ob.originalKg||0);
  const usedKg = origKg - remKg;
  const confirmMsg = `Close open bag: ${ob.orderId}?\n\n`+
    `• ${ob.bagName} (${ob.bagWeight})\n`+
    `• ${remKg.toFixed(2)} kg remaining out of ${origKg} kg\n`+
    `• ${usedKg.toFixed(2)} kg already sold\n\n`+
    (remKg>0 ? `The remaining ${remKg.toFixed(2)} kg will be returned to bag stock (converted back to full bags if enough).`
             : 'All stock was sold. Record will be removed.');
  if(!confirm(confirmMsg)) return;
  const {doc, deleteDoc, updateDoc} = window._fb;
  // If remaining kg is enough to make a full bag, return it to stock
  const bag = bags.find(b=>b.id===bagId);
  if(bag && remKg>0){
    const bagWeightKg = parseBagWeightKg(bag.weight);
    const fullBagsToReturn = bagWeightKg>0 ? Math.floor(remKg/bagWeightKg) : 0;
    if(fullBagsToReturn>0){
      await updateDoc(doc(window._db,'bags',bagId),{
        stock: Number(bag.stock) + fullBagsToReturn
      });
      toast(`Returned ${fullBagsToReturn} bag(s) to stock · ${ob.orderId} closed`);
    } else {
      toast(`${ob.orderId} closed · ${remKg.toFixed(2)} kg written off (less than 1 full bag)`);
    }
  } else {
    toast(`${ob.orderId} removed`);
  }
  // Delete the openedBag record
  await deleteDoc(doc(window._db,'openedBags',openBagDocId));
}
let looseSaleBagId = null;
let looseOpenBagId = null; // openedBags doc ID

function openLooseSaleModal(bagId){
  const activeRecords = bagId
    ? openedBags.filter(ob=>ob.bagId===bagId && Number(ob.remainingKg||0)>0)
    : openedBags.filter(ob=>Number(ob.remainingKg||0)>0);
  if(!activeRecords.length){
    toast(bagId ? 'No open bags for this rice. Tap "📦 Open bag" first.' : 'No open bags. Open a bag first.');
    return;
  }
  looseOpenBagId = activeRecords[0].id;
  looseSaleBagId = activeRecords[0].bagId;
  const sel = document.getElementById('loose-bag-select');
  sel.innerHTML = activeRecords.map(ob=>
    `<option value="${ob.id}" ${ob.id===looseOpenBagId?'selected':''}>
      ${ob.bagName} (${ob.bagWeight}) · ${ob.orderId} · ${Number(ob.remainingKg).toFixed(2)} kg left
    </option>`).join('');
  document.getElementById('loose-bag-selector-wrap').style.display = activeRecords.length>1 ? 'block' : 'none';
  ['ls-qty','ls-cust','ls-phone','ls-address'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  document.getElementById('ls-unit').value='kg';
  document.getElementById('ls-type').value='walkin';
  document.getElementById('ls-address-wrap').style.display='none';
  document.getElementById('loose-preview').style.display='none';
  onLooseBagSelect();
  document.getElementById('loose-modal').classList.remove('hidden');
}

function onLooseBagSelect(){
  const sel = document.getElementById('loose-bag-select');
  looseOpenBagId = sel.value || looseOpenBagId;
  const ob = openedBags.find(x=>x.id===looseOpenBagId);
  if(!ob) return;
  looseSaleBagId = ob.bagId;
  const bag = bags.find(b=>b.id===ob.bagId);
  document.getElementById('loose-bag-display').style.display='flex';
  document.getElementById('ls-img').innerHTML = bag?.img
    ? `<img src="${bag.img}" style="width:100%;height:100%;object-fit:cover;border-radius:6px">` : '🌾';
  document.getElementById('ls-name').textContent = `${ob.bagName} · ${ob.orderId}`;
  document.getElementById('ls-avail').textContent = `${Number(ob.remainingKg||0).toFixed(2)} kg available`;
  document.getElementById('ls-pricekg').textContent = `₹${ob.pricePerKg||'?'} per kg`;
  document.getElementById('ls-price-per-kg').value = ob.pricePerKg||'';
  updateLoosePreview();
}

function toggleLooseInvoice(){
  const t = document.getElementById('ls-type').value;
  document.getElementById('ls-address-wrap').style.display=(t==='whatsapp'||t==='delivery')?'block':'none';
}

function updateLoosePreview(){
  const ob = openedBags.find(x=>x.id===looseOpenBagId);
  if(!ob) return;
  const qtyRaw = parseFloat(document.getElementById('ls-qty').value)||0;
  const unit = document.getElementById('ls-unit').value;
  const pricePerKg = parseFloat(document.getElementById('ls-price-per-kg').value)||0;
  const qtyKg = unit==='g' ? qtyRaw/1000 : qtyRaw;
  const prev = document.getElementById('loose-preview');
  const avail = Number(ob.remainingKg||0);
  if(!qtyKg||!pricePerKg){ prev.style.display='none'; return; }
  if(qtyKg>avail){
    prev.style.display='block';
    prev.style.background='var(--red-light)'; prev.style.color='var(--red)';
    prev.innerHTML=`⚠️ Not enough! Only ${avail.toFixed(2)} kg available in ${ob.orderId}.`;
    return;
  }
  const total = pricePerKg*qtyKg;
  const profit = (pricePerKg-(ob.costPerKg||0))*qtyKg;
  prev.style.display='block'; prev.style.background=''; prev.style.color='';
  prev.innerHTML = `⚖️ Selling <strong>${unit==='g'?qtyRaw+'g':qtyKg+' kg'}</strong> of ${ob.bagName}<br>
    💵 <strong>₹${pricePerKg}/kg × ${qtyKg} kg = ₹${total.toLocaleString('en-IN')}</strong><br>
    ${ob.costPerKg>0?`📊 Profit: ₹${profit.toFixed(2)} on this sale<br>`:''}
    📦 Remaining after sale: <strong>${(avail-qtyKg).toFixed(2)} kg</strong> in ${ob.orderId}`;
}

async function recordLooseSale(){
  const ob = openedBags.find(x=>x.id===looseOpenBagId);
  if(!ob){ toast('No open bag selected'); return; }
  const bag = bags.find(b=>b.id===ob.bagId);
  const qtyRaw = parseFloat(document.getElementById('ls-qty').value)||0;
  const unit = document.getElementById('ls-unit').value;
  const pricePerKg = parseFloat(document.getElementById('ls-price-per-kg').value)||0;
  const cust = document.getElementById('ls-cust').value.trim();
  const phone = document.getElementById('ls-phone').value.trim();
  const type = document.getElementById('ls-type').value;
  const address = (document.getElementById('ls-address')?.value||'').trim();
  const qtyKg = unit==='g' ? qtyRaw/1000 : qtyRaw;
  if(!qtyKg||qtyKg<=0){ toast('Enter quantity'); return; }
  if(!pricePerKg){ toast('Enter price per kg'); return; }
  const avail = Number(ob.remainingKg||0);
  if(qtyKg>avail){ toast(`Only ${avail.toFixed(2)} kg available in ${ob.orderId}!`); return; }
  const total   = Math.round(pricePerKg*qtyKg*100)/100;
  const profit  = Math.round((pricePerKg-(ob.costPerKg||0))*qtyKg*100)/100;
  const invoiceNo = 'INV-L'+Date.now().toString().slice(-6);
  const orderId = 'ORD-L'+Date.now().toString().slice(-8);
  const {doc,updateDoc,addDoc,collection} = window._fb;
  const sale = {
    bagId:ob.bagId, bagName:ob.bagName, weight:ob.bagWeight,
    openBagOrderId: ob.orderId,
    saleMode:'loose',
    qtyKg, qtyDisplay: unit==='g'?`${qtyRaw}g`:`${qtyKg}kg`,
    pricePerKg, costPerKg:ob.costPerKg||0,
    total, profit, invoiceNo, orderId,
    customer:cust, phone, address, type,
    qty:1, pricePerBag:total, costPerBag:0,
    date:Date.now(), recordedBy:currentUser?.email||''
  };
  await addDoc(collection(window._db,'sales'), sale);
  // Deduct remainingKg from the specific openedBags record
  const newRemaining = Math.round((avail-qtyKg)*1000)/1000;
  await updateDoc(doc(window._db,'openedBags',looseOpenBagId),{remainingKg: newRemaining});
  if(phone&&cust){
    const existing = customers.find(c=>c.phone===phone);
    if(!existing) await addDoc(collection(window._db,'customers'),{name:cust,phone,area:'',notes:'',totalOrders:1,createdAt:Date.now()});
  }
  toast(`✅ ${ob.orderId} · ${qtyKg}kg sold → ₹${total}`);
  closeModal('loose-modal');
  if(type==='whatsapp'||type==='delivery') showLooseInvoice(sale);
}

function showLooseInvoice(sale){
  // Build an invoice-compatible object and call showInvoice
  const looseSaleObj = {
    orderId: sale.orderId,
    invoiceNo: sale.invoiceNo,
    customer: sale.customer,
    phone: sale.phone,
    address: sale.address||'',
    date: sale.date,
    type: sale.type,
    _isLoose: true,
    _bagName: sale.bagName,
    _qtyDisplay: sale.qtyDisplay,
    _pricePerKg: sale.pricePerKg,
    _total: sale.total
  };
  showInvoice(looseSaleObj);
}
