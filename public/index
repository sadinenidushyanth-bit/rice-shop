<body>

<!-- ══ AUTH SCREEN ══ -->
<div id="auth-screen" class="auth-screen">
  <div class="auth-box">
    <div class="auth-logo">🌾</div>
    <div class="auth-title">Rice Shop Manager</div>
    <div class="auth-sub">Sign in to manage your shop</div>
    <div id="auth-error" class="auth-error"></div>
    <div class="form-group">
      <label class="form-label">Email</label>
      <input type="email" id="auth-email" class="form-control" placeholder="your@email.com"
